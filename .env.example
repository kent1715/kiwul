# KIWUL LOCAL-FIRST AI CONFIGURATION
# Salin file ini menjadi .env untuk diaktifkan

PORT=3000
HOST=127.0.0.1

# Optional Gemini API Key (Apabila ingin menggunakan Gemini secara hybrid)
GEMINI_API_KEY=

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3:8b

# Local Image (Z-Image Turbo proxy)
ZIMAGE_BASE_URL=http://127.0.0.1:9100/v1
ZIMAGE_MODEL=z-image-turbo

# Local Video (LTX Comfy dynamic proxy)
LTX_BASE_URL=http://127.0.0.1:9200/v1
LTX_MODEL=comfy-ltxv-i2v

# Local TTS Voice (Edge-TTS)
EDGE_TTS_VOICE=id-ID-ArdiNeural
